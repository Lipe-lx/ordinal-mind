{
  "name": "ordinalmind",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "preview:static": "node scripts/serve-spa.mjs dist/client 4173",
    "deploy": "npm run build && wrangler deploy",
    "types": "wrangler types",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:ui": "playwright test",
    "test:ui:update": "playwright test --update-snapshots",
    "test:smoke": "vitest run tests/worker/chronicleSmoke.test.ts tests/worker/mcpSmoke.test.ts",
    "test:watch": "vitest",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "db:migrate:local": "wrangler d1 migrations apply ordinal-mind-wiki --local",
    "db:migrate:remote": "wrangler d1 migrations apply ordinal-mind-wiki --remote",
    "db:migrations:list:local": "wrangler d1 migrations list ordinal-mind-wiki --local",
    "db:migrations:list:remote": "wrangler d1 migrations list ordinal-mind-wiki --remote",
    "cf:kv:export": "node scripts/cloudflare/kv-export.mjs",
    "cf:kv:import": "node scripts/cloudflare/kv-import-bulk.mjs"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.12.3",
    "cbor": "^10.0.12",
    "cytoscape": "^3.33.3",
    "cytoscape-cola": "^2.5.1",
    "cytoscape-elk": "^2.3.0",
    "cytoscape-fcose": "^2.2.0",
    "fflate": "^0.8.2",
    "motion": "^12.0.0",
    "p5": "^2.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/cytoscape-fcose": "^2.2.5",
    "@types/node": "^25.6.0",
    "@types/p5": "^1.7.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.88.0"
  }
}
